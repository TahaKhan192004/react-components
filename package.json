{
  "name": "@yourcargoc/ui",
  "version": "0.1.3",
  "description": "YCC APIP Platform component library — React 18, TypeScript, Tailwind CSS",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/components/index.d.ts"
    },
    "./dist/ycc-ui.css": "./dist/ycc-ui.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:app": "tsc -b && vite build",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.build.json",
    "build:css": "tailwindcss -i src/index.css -o dist/ycc-ui.css --minify",
    "build": "npm run build:lib && npm run build:css",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {
    "lucide-react": ">=0.383.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "lucide-react": "^0.383.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^5.0.3"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "ycc",
    "logistics",
    "customs",
    "freight"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TahaKhan192004/ycc-ui"
  },
  "license": "MIT"
}
